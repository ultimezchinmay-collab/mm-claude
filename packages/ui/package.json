{
  "name": "@meetmedico/ui",
  "version": "0.1.0",
  "description": "MeetMedico shared design system — tokens, theme, and React Native components (web-compatible via react-native-web).",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./tokens": "./src/tokens/index.ts",
    "./components/Button": "./src/components/Button/index.ts",
    "./styles.css": "./src/tokens/variables.css",
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "tokens:css": "tsx src/tokens/generate-css-variables.ts",
    "build": "npm run tokens:css && tsup",
    "test": "jest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=19",
    "react-native": ">=0.86"
  },
  "dependencies": {
    "react-native-paper": "^5.15.3",
    "react-native-safe-area-context": "~5.7.0"
  },
  "devDependencies": {
    "@react-native/jest-preset": "*",
    "@hugeicons/core-free-icons": "^4.2.2",
    "@hugeicons/react-native": "^1.0.15",
    "@testing-library/react-native": "^13.0.1",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.2",
    "jest": "^29.7.0",
    "react-native-svg": "15.15.4",
    "react-test-renderer": "19.2.3",
    "tsup": "^8.3.5",
    "tsx": "^4.23.0",
    "typescript": "~6.0.3"
  }
}
